# ── Backend ───────────────────────────────────────────────────────────────────
# Async DB URL. SQLite for dev; swap to postgresql+asyncpg://user:pass@host/db for prod
DATABASE_URL=sqlite+aiosqlite:///./invoices.db

# JWT signing secret — CHANGE THIS in production
SECRET_KEY=change-me-to-a-long-random-string

# Token TTL in minutes (default 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Clerk (https://clerk.com) ─────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Supabase (https://supabase.com) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
